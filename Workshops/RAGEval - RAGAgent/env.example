# ─────────────────────────────────────────────────────────────────
# RAGEval — Bring Your Own Docs Evaluator
# Environment Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
# To activate:
#   Windows PowerShell:  Get-Content .env | ForEach-Object { $env:$_ }
#   Windows CMD:         for /f "delims=" %x in (.env) do set %x
#   Mac/Linux:           export $(cat .env | xargs)
#   Or just: uvicorn main:app --reload --port 8000  (python-dotenv loads it automatically)
# ─────────────────────────────────────────────────────────────────

# ── PROVIDER: choose "github" or "foundry" ───────────────────────
LLM_PROVIDER=github

# ── GITHUB MODELS ─────────────────────────────────────────────────
# Get your token at: https://github.com/settings/tokens
# Required scopes: models:read
GITHUB_TOKEN=your_github_pat_here

# GitHub Models inference endpoint (do not change)
GITHUB_ENDPOINT=https://models.github.ai/inference

# Model to use — see full list at: https://github.com/marketplace/models
# Recommended free-tier options:
#   openai/gpt-4o-mini        (fast, cheap, great for RAG + question generation)
#   openai/gpt-4.1-mini       (slightly newer)
#   meta/Llama-3.2-11B-Vision-Instruct
LLM_MODEL=openai/gpt-4o-mini

# ── FOUNDRY LOCAL (alternative to GitHub Models) ──────────────────
# Uncomment and set LLM_PROVIDER=foundry to use on-device inference
# Install: winget install Microsoft.FoundryLocal
# Pull model: foundry model download phi-3.5-mini
# FOUNDRY_MODEL_ALIAS=phi-3.5-mini
