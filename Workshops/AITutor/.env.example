# ─────────────────────────────────────────────────────────────────────────────
# AI TUTOR  –  Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

MODEL_PROVIDER=github_models

# ══════════════════════════════════════════════════════════════════════════════
# OPTION A: GitHub Models
# ══════════════════════════════════════════════════════════════════════════════
GITHUB_TOKEN=<enter your API key here>
GITHUB_ENDPOINT=https://models.github.ai/inference
GITHUB_MODEL_ID=gpt-4o-mini

# ══════════════════════════════════════════════════════════════════════════════
# OPTION B: Foundry Local
# ══════════════════════════════════════════════════════════════════════════════
# MODEL_PROVIDER=foundry_local
# FOUNDRYLOCAL_ENDPOINT=http://localhost:5272/v1
# FOUNDRYLOCAL_MODEL_DEPLOYMENT_NAME=phi-3.5-mini

# ══════════════════════════════════════════════════════════════════════════════
# OPTION C: Azure OpenAI
# ══════════════════════════════════════════════════════════════════════════════
# MODEL_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
# AZURE_OPENAI_API_KEY=...

# ══════════════════════════════════════════════════════════════════════════════
# OPTION D: OpenAI
# ══════════════════════════════════════════════════════════════════════════════
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL_ID=gpt-4o-mini

# ══════════════════════════════════════════════════════════════════════════════
# OBSERVABILITY — VS Code AI Toolkit
#
# Use signal-specific endpoints with full /v1/* paths.
# MAF passes OTEL_EXPORTER_OTLP_ENDPOINT directly to the exporter constructor
# (bypassing SDK auto-path logic), so bare base URLs produce 404 errors.
# Signal-specific vars always include the full path and work correctly.
# ══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Turn on MAF span generation
ENABLE_INSTRUMENTATION=true

# [REQUIRED] Include token counts + prompt/response content in spans
ENABLE_SENSITIVE_DATA=true

# [REQUIRED] Force HTTP — VS Code AI Toolkit uses HTTP/protobuf, NOT gRPC
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# [REQUIRED] Signal-specific endpoints with full paths (avoids 404)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs

# Service name shown in VS Code AI Toolkit trace list
OTEL_SERVICE_NAME=ai-tutor

# [OPTIONAL] Also print spans to console (dev debugging)
ENABLE_CONSOLE_EXPORTERS=true

# [OPTIONAL] Azure Monitor / Application Insights
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGIN=http://localhost:5500
